---
const year = new Date().getFullYear();
---

<footer class="bg-navy text-white mt-20">
  <div class="max-w-6xl mx-auto px-4 md:px-8 py-14">
    <div class="grid md:grid-cols-3 gap-10 mb-10">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-3 mb-4 group">
          <div class="w-9 h-9 bg-teal rounded-lg flex items-center justify-center text-white font-bold text-sm">LCM</div>
          <span class="font-semibold text-white">Luis Carlos Moreno</span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed">
          Engineering Solutions. Empowering Educators.<br />
          Learning Innovation &amp; Technology Coach | AI Integration Specialist
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-400 mb-4">Navigate</h3>
        <ul class="space-y-2 text-sm">
          {[
            { href: '/', label: 'Home' },
            { href: '/experience', label: 'My Journey' },
            { href: '/work', label: 'Selected Work' },
            { href: '/innovations', label: 'Signature Innovations' },
            { href: '/work-with-me', label: 'Work With Me' },
            { href: '/blog', label: 'Blog' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-gray-400 hover:text-white transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-400 mb-4">Connect</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href="mailto:mr.luisc@gmail.com" class="flex items-center gap-2 text-gray-400 hover:text-white transition-colors">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              mr.luisc@gmail.com
            </a>
          </li>
          <li>
            <a href="https://www.linkedin.com/in/luiscarlosmorenorivero/" target="_blank" rel="noopener" class="flex items-center gap-2 text-gray-400 hover:text-white transition-colors">
              <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          </li>
          <li>
            <a href="/work-with-me#contact" class="flex items-center gap-2 text-amber hover:text-amber-light transition-colors font-medium">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              Work With Me
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-gray-500">
      <p>© {year} Luis Carlos Moreno. All rights reserved.</p>
      <p>Venezuela · International · Remote worldwide</p>
    </div>
  </div>
</footer>
