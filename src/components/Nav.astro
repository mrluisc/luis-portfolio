---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/experience', label: 'My Journey' },
  { href: '/innovations', label: 'Innovations' },
  { href: '/work-with-me', label: 'Work With Me' },
  { href: '/blog', label: 'Blog' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-sm border-b border-gray-100 shadow-sm">
  <nav class="max-w-6xl mx-auto px-4 md:px-8 flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-9 h-9 bg-teal rounded-lg flex items-center justify-center text-white font-bold text-sm group-hover:bg-teal-600 transition-colors">
        LCM
      </div>
      <span class="font-semibold text-navy hidden sm:block group-hover:text-teal transition-colors">
        Luis Carlos Moreno
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-1">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'bg-teal-50 text-teal'
                : 'text-gray-600 hover:text-teal hover:bg-gray-50'
            }`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA + hamburger -->
    <div class="flex items-center gap-3">
      <a href="/work-with-me#contact" class="hidden md:inline-flex btn-primary text-sm py-2 px-4">
        Let's Connect
      </a>
      <button id="nav-toggle" class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 transition-colors" aria-label="Toggle menu">
        <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white px-4 pb-4">
    <ul class="flex flex-col gap-1 pt-2">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors ${
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'bg-teal-50 text-teal'
                : 'text-gray-700 hover:bg-gray-50'
            }`}
          >
            {label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a href="/work-with-me#contact" class="btn-primary w-full justify-center text-sm py-2.5">
          Let's Connect
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });
</script>
