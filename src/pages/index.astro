---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Home" description="Learning Innovation & Technology Coach, AI Integration Specialist, and Co-creator of the HUMAN Framework. Engineering solutions, empowering educators.">
  <Nav />
  <main>

    <!-- ─── HERO ──────────────────────────────────────────────── -->
    <section class="bg-gradient-to-br from-navy via-teal-900 to-teal text-white py-20 md:py-32 overflow-hidden relative">
      <div class="absolute inset-0 opacity-5 bg-[radial-gradient(circle_at_30%_50%,_#F4A442_0%,_transparent_60%)]"></div>
      <div class="max-w-6xl mx-auto px-4 md:px-8 relative">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <span class="tag bg-white/10 text-white border border-white/20 mb-6 inline-block">
              Joining Shanghai American School · Puxi Middle School · August 2026 · Available for consulting
            </span>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4">
              Luis Carlos <span class="text-amber">Moreno</span>
            </h1>
            <p class="text-teal-200 font-medium text-lg mb-2">
              EdTech Coordinator &nbsp;·&nbsp; Learning Innovation &amp; Technology Coach
            </p>
            <p class="text-teal-200 font-medium text-base mb-6">
              Co-creator of the HUMAN Framework &nbsp;·&nbsp; GOA Instructor &nbsp;·&nbsp; Apple Distinguished School lead
            </p>
            <p class="text-2xl md:text-3xl font-semibold text-amber mb-8 leading-snug">
              I build school systems<br />that outlive their builder.
            </p>
            <p class="text-gray-300 text-lg leading-relaxed mb-10 max-w-lg">
              A Venezuelan-born systems engineer turned international educator, I work at the
              intersection of coaching and code: close enough to pedagogy to know what teachers
              actually need, technical enough to build it myself. At my last school, the systems I
              built became the infrastructure: the dashboard 50+ leaders run curriculum from, the
              app that tracks 700+ students' health check-ins, the engine that places an entire grade
              into its signature trips. All of it still running after I left. That was the point.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/experience" class="btn-amber">Explore My Journey</a>
              <a href="/work-with-me" class="btn-secondary border-white/40 text-white hover:bg-white hover:text-teal">Work With Me</a>
            </div>
          </div>
          <div class="flex justify-center md:justify-end">
            <div class="relative">
              <div class="absolute -inset-4 bg-amber/20 rounded-3xl blur-xl"></div>
              <img
                src="/images/headshot-main.jpeg"
                alt="Luis Carlos Moreno"
                class="relative w-72 h-72 md:w-80 md:h-80 lg:w-96 lg:h-96 rounded-2xl object-cover object-top shadow-2xl ring-4 ring-white/10"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── STATS BAR ─────────────────────────────────────────── -->
    <section class="bg-teal text-white py-8">
      <div class="max-w-6xl mx-auto px-4 md:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          {[
            { value: '26', label: 'New teachers onboarded through my system, before day one' },
            { value: '50+', label: 'School leaders running curriculum from my dashboard' },
            { value: '700+', label: 'Students covered by school-wide systems' },
            { value: '10+', label: 'Tools shipped by request, adopted by name' },
          ].map(({ value, label }) => (
            <div>
              <div class="text-3xl font-bold text-amber">{value}</div>
              <div class="text-sm text-teal-100 mt-1">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── ABOUT ──────────────────────────────────────────────── -->
    <section class="py-20 md:py-28 bg-white">
      <div class="max-w-6xl mx-auto px-4 md:px-8">
        <div class="grid md:grid-cols-2 gap-14 items-center">
          <div>
            <span class="tag mb-4">About Me</span>
            <h2 class="section-title">I Build Systems That Make Institutional Knowledge Stick</h2>
            <div class="space-y-4 text-gray-700 leading-relaxed">
              <p>
                ¡Hola, hola! I'm Luis Carlos, a Venezuelan-born systems engineer who became an educator.
                It runs in the family: my grandmother founded two schools in Valle de la Pascua, the small
                town where I grew up, and I am the third generation to make teaching my work. I left for
                Texas at 15 to learn English, and have since lived and worked across 5 countries on
                three continents.
              </p>
              <p>
                At the American International School Chennai, an IB World School of 700+ students, I was
                the <strong>Learning Innovation &amp; Technology Coach and AI Initiatives Coordinator</strong>.
                I led the school's Apple Distinguished School certification, co-created its framework for
                ethical AI use, and coached 110+ faculty. I started my career in the classroom teaching MYP
                Mathematics, and that path is exactly the point: I work at the intersection of coaching and
                engineering, translating what teachers actually need into tools they actually adopt.
              </p>
              <p>
                Here's the test I hold my own work to: <strong>does it keep running after I leave the
                room?</strong> The curriculum dashboard I built is how 50+ AISC leaders see their program,
                and in May 2026, the school's director sent it to 26 incoming teachers as the very first
                onboarding resource they received, before they'd even arrived in Chennai. The
                trip-assignment engine shipped with a 50-page operations manual so the program runs
                identically without me. That's what I mean by making institutional knowledge stick: not
                tools, infrastructure.
              </p>
              <p>
                In <strong>August 2026 I'm bringing that playbook to Shanghai American School (SAS Puxi,
                Middle School)</strong> as EdTech Coordinator. Same belief, new campus: technology serves
                people, not the other way around. And one more thing every move has taught me: leaving
                your comfort zone gets easier the more you do it.
              </p>
              <p class="italic text-teal font-medium border-l-4 border-teal pl-4">
                "His support has significantly reduced stress for many of us and has made a complicated
                process much smoother." Elizabeth Keogh, in a commendation to the Deputy Head
              </p>
            </div>
            <div class="flex flex-wrap gap-3 mt-6 text-sm text-gray-600">
              <span class="bg-gray-100 rounded-full px-3 py-1">Venezuelan</span>
              <span class="bg-gray-100 rounded-full px-3 py-1">Queer Educator</span>
              <span class="bg-gray-100 rounded-full px-3 py-1">5 Countries</span>
              <span class="bg-gray-100 rounded-full px-3 py-1">EN · ES · PT</span>
            </div>
          </div>
          <div class="relative">
            <img
              src="/images/headshot-2.jpeg"
              alt="Luis Carlos Moreno presenting"
              class="rounded-2xl shadow-lg w-full object-cover max-h-[480px]"
            />
            <div class="absolute -bottom-4 -right-4 bg-amber text-white rounded-xl px-5 py-3 shadow-lg text-sm font-semibold">
              60+ countries visited
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── SIGNATURE INNOVATIONS ─────────────────────────────── -->
    <section class="py-20 md:py-28 bg-gray-50">
      <div class="max-w-6xl mx-auto px-4 md:px-8">
        <div class="text-center mb-14">
          <span class="tag mb-4">Signature Innovations</span>
          <h2 class="section-title">Tools &amp; Frameworks That Transform Education</h2>
          <p class="section-subtitle mx-auto">
            From ethical AI integration guidelines to data-driven lesson analysis: built for real classrooms, real teachers, real impact.
          </p>
        </div>
        <div class="grid md:grid-cols-2 gap-8">

          <!-- HUMAN Framework -->
          <div class="card group hover:border-teal-200">
            <div class="flex items-start gap-4 mb-4">
              <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-teal group-hover:text-white transition-colors">
                <svg class="w-6 h-6 text-teal group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <span class="text-xs font-semibold uppercase tracking-wider text-teal">Co-created with María Pérez Talavera</span>
                <h3 class="text-xl font-bold text-navy mt-0.5">The HUMAN Framework</h3>
              </div>
              <div class="ml-auto flex items-center gap-1.5 flex-shrink-0">
                <span class="status-dot"></span>
                <span class="status-label">Operational</span>
              </div>
            </div>
            <p class="text-gray-600 mb-5 leading-relaxed">
              School-wide guidelines for ethical, human-centered AI integration in education. Five levels
              from pure human thinking to AI-created elements, give teachers a clear, flexible map
              for responsible AI use that preserves learning and maintains integrity.
            </p>
            <img src="/images/human-framework.png" alt="HUMAN Framework diagram" class="w-full rounded-xl mb-5 border border-gray-100" />
            <div class="flex flex-wrap gap-2 text-xs mb-5">
              {['Preserving Learning', 'Maintaining Integrity', 'AIFE Jakarta', 'Data in Schools KL'].map(t => (
                <span class="bg-teal-50 text-teal rounded-full px-3 py-1 font-medium">{t}</span>
              ))}
            </div>
            <a href="/innovations#human-framework" class="btn-secondary text-sm py-2">
              Learn More →
            </a>
          </div>

          <!-- LEA -->
          <div class="card group hover:border-amber/30">
            <div class="flex items-start gap-4 mb-4">
              <div class="w-12 h-12 bg-amber/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-amber group-hover:text-white transition-colors">
                <svg class="w-6 h-6 text-amber group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
              </div>
              <div>
                <span class="text-xs font-semibold uppercase tracking-wider text-amber">AI-Powered Tool</span>
                <h3 class="text-xl font-bold text-navy mt-0.5">Learning Experience Analyzer (LEA)</h3>
              </div>
              <div class="ml-auto flex items-center gap-1.5 flex-shrink-0">
                <span class="status-dot"></span>
                <span class="status-label">Operational</span>
              </div>
            </div>
            <p class="text-gray-600 mb-5 leading-relaxed">
              Teachers paste a learning activity and LEA instantly analyzes it against UbD, UDL, Bloom's
              Taxonomy, the HUMAN Framework, and school-specific mission &amp; values, generating
              actionable improvement recommendations in seconds.
            </p>
            <img src="/images/lea-web.jpeg" alt="LEA tool interface" class="w-full rounded-xl mb-5 border border-gray-100" />
            <div class="grid grid-cols-3 gap-3 text-center mb-5">
              {[
                { who: 'Students', what: 'Better-designed learning experiences' },
                { who: 'Teachers', what: 'Streamlined planning, less cognitive load' },
                { who: 'Leadership', what: 'Data for strategic decisions' },
              ].map(({ who, what }) => (
                <div class="bg-gray-50 rounded-xl p-3">
                  <div class="font-semibold text-navy text-sm">{who}</div>
                  <div class="text-xs text-gray-500 mt-1 leading-snug">{what}</div>
                </div>
              ))}
            </div>
            <a href="/innovations#lea" class="btn-secondary text-sm py-2">
              Learn More →
            </a>
          </div>

        </div>
        <div class="text-center mt-10">
          <a href="/innovations" class="btn-primary">See All Innovations</a>
        </div>
      </div>
    </section>

    <!-- ─── BUILT ON REQUEST ──────────────────────────────────── -->
    <section class="py-20 md:py-28 bg-navy text-white">
      <div class="max-w-4xl mx-auto px-4 md:px-8">
        <div class="text-center mb-10">
          <span class="tag bg-white/10 text-white border border-white/20 mb-4 inline-block">Built on Request</span>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">The Case Studies Are Five. The Requests Never Stopped.</h2>
          <p class="text-gray-300 text-lg leading-relaxed max-w-2xl mx-auto">
            Case studies get the spotlight. Most of what I built at AISC started smaller: a colleague
            mentioned a headache, and a few days later there was a tool. More than ten of these are in
            the record by name, each one adopted by the person who asked for it. This is the part of the
            job I care about most. Not the flagship launch. The Tuesday request.
          </p>
        </div>

        <blockquote class="border-l-4 border-amber pl-6 py-2 mb-12 max-w-2xl mx-auto">
          <p class="text-xl text-amber font-medium italic leading-snug">
            "Luis Carlos Moreno is our Technology and Innovation Coach, making amazing tools to improve
            teachers' lives, among his many other activities."
          </p>
          <p class="text-sm text-gray-400 mt-3">
            Greg Clinton, Deputy Head of School, introducing me to an outside AI consultant
          </p>
        </blockquote>

        <div class="space-y-1 font-mono text-sm">
          {[
            { date: '2025-09', name: 'DT & Trip Safety Consent System', dept: 'MS Design Technology', desc: 'Digital consent forms with a signature-tracking dashboard, used daily by the department.', receipt: '"It has made a massive difference in our department."', who: 'Jay Hart, DT Teacher' },
            { date: '2025-09', name: 'Science Report Comment Generator', dept: 'MS Science', desc: 'AI-assisted comment drafting with a walkthrough video, built for the whole team.', receipt: '"This spreadsheet is incredible, and the video is so concise and clear."', who: 'Kelsey Bull, MS Principal' },
            { date: '2025', name: 'French Report Comment Generator', dept: 'World Language', desc: 'Same pattern, second subject, adapted to the department\'s rubrics.', receipt: null, who: null },
            { date: '2025-12', name: 'EAL Progress Tracker', dept: 'EAL Department', desc: 'Gamified student-progress tool with linked reflection forms.', receipt: '"\'Game-like\' features... Impressive!"', who: 'Suzanne Brigham, EAL Teacher' },
            { date: '2025', name: 'MS Report Card Comment System v4.0', dept: 'All MS Teachers', desc: '1,914 comments managed per cycle, AI comment banks, one-click export to PowerTeacher Pro.', receipt: null, who: null },
            { date: '2025-10', name: 'Math Shark Tank Analysis Report', dept: 'Curriculum Leadership', desc: 'A data tool for curriculum-goal alignment, shared with schools abroad.', receipt: '"LC, this is SO cool... Amazing work!"', who: 'Kyle Martin, ISKL' },
            { date: '2025', name: 'Meeting Notes Auto-Transcriber', dept: 'ES Leadership', desc: 'Automated transcription and notes for leadership meetings.', receipt: '"This is amazing. I want to learn how to do this."', who: 'Lynn Schneider, ES Principal' },
            { date: '2025', name: 'Innovation Bot', dept: 'Innovation in T&L Council', desc: 'A scoped AI assistant that helped faculty refine their innovation pitches.', receipt: null, who: null },
            { date: '2025-02', name: 'AI Book Club Companion Site', dept: '20+ Educators', desc: 'Session resources and discussion hub for "Exploring Tomorrow."', receipt: null, who: null },
            { date: '2024', name: 'Learning Experience Analyzer (LEA)', dept: 'School-wide', desc: 'Multi-framework lesson analysis; the tool that grew into a data system.', receipt: null, who: null },
          ].map(({ date, name, dept, desc, receipt, who }) => (
            <details class="group border-b border-white/10">
              <summary class="flex items-center gap-4 py-3 cursor-pointer list-none hover:text-amber transition-colors">
                <span class="status-dot flex-shrink-0"></span>
                <span class="text-gray-400 w-20 flex-shrink-0">{date}</span>
                <span class="font-semibold flex-1">{name}</span>
                <span class="text-gray-400 text-xs hidden md:inline">{dept}</span>
                <span class="text-gray-500 group-open:rotate-180 transition-transform flex-shrink-0">▾</span>
              </summary>
              <div class="pb-4 pl-10 pr-4 text-gray-300 font-sans">
                <p class="mb-2">{desc}</p>
                {receipt && (
                  <p class="border-l-2 border-amber/50 pl-3 italic text-amber-light text-sm">
                    {receipt}<span class="block not-italic text-gray-400 mt-1">{who}</span>
                  </p>
                )}
              </div>
            </details>
          ))}
          <div class="flex items-center gap-4 py-3 text-gray-500">
            <span class="status-dot-retired flex-shrink-0"></span>
            <span class="w-20 flex-shrink-0">2026-…</span>
            <span class="flex-1">your school's tool</span>
            <a href="/work-with-me" class="text-amber hover:underline text-xs">get in touch →</a>
          </div>
        </div>

        <p class="text-center text-gray-400 text-sm mt-10 max-w-xl mx-auto">
          Every entry above was requested by a colleague and adopted by name. When a number is on this
          site, there is an email behind it. And the list is an undercount: the record keeps surfacing more.
        </p>
      </div>
    </section>

    <!-- ─── CAREER HIGHLIGHTS ─────────────────────────────────── -->
    <section class="py-20 md:py-28 bg-white">
      <div class="max-w-6xl mx-auto px-4 md:px-8">
        <div class="text-center mb-14">
          <span class="tag mb-4">Experience</span>
          <h2 class="section-title">A Career Built on Every Angle</h2>
          <p class="section-subtitle mx-auto">
            Having held almost every role in a school, I see education as a complete system, and build solutions that work for everyone.
          </p>
        </div>
        <div class="relative pl-6 border-l-2 border-teal-100 space-y-10 max-w-3xl mx-auto">
          {[
            {
              years: '2026 – Present',
              role: 'EdTech Coordinator',
              org: 'Shanghai American School (SAS Puxi), China',
              badge: 'Current',
              notes: 'Starting August 2026, Middle School',
            },
            {
              years: '2024 – 2026',
              role: 'Learning Innovation & Technology Coach · AI Initiatives Coordinator',
              org: 'American International School Chennai (AISC), India',
              badge: null,
              notes: 'Led Apple Distinguished School certification · Co-created HUMAN Framework · Built LEA · Coached 110+ faculty',
            },
            {
              years: '2024 – Present',
              role: 'Geometry & Game Theory Instructor',
              org: 'Global Online Academy (GOA), Global',
              badge: 'Current',
              notes: 'Teaching Geometry and Game Theory online to students worldwide',
            },
            {
              years: '2021 – 2024',
              role: 'MYP Mathematics Teacher · DEIJ Taskforce',
              org: 'Vientiane International School, Laos',
              badge: null,
              notes: 'Presented at AIELOC Hanoi 2024 · Contributed to DEIJ culture initiatives',
            },
            {
              years: '2016 – 2021',
              role: 'EdTech Coordinator · Instructional Coach · Math Dept Head · Learning Support',
              org: 'International School of Panama',
              badge: null,
              notes: '5 roles across 5 years, building the full picture of how schools work',
            },
            {
              years: '2015 – 2016',
              role: 'STEM & Robotics Teacher · Head of IT Department',
              org: 'Colegio Isaac Rabin, Panama',
              badge: null,
              notes: 'Founded robotics program and led IT infrastructure',
            },
          ].map(({ years, role, org, badge, notes }) => (
            <div class="relative">
              <div class="absolute -left-[29px] w-4 h-4 rounded-full bg-teal border-2 border-white shadow-sm"></div>
              <div class="card ml-2">
                <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
                  <span class="text-sm text-gray-500 font-medium">{years}</span>
                  {badge && <span class="tag text-xs">{badge}</span>}
                </div>
                <h3 class="font-semibold text-navy text-base mb-0.5">{role}</h3>
                <p class="text-teal text-sm font-medium mb-2">{org}</p>
                <p class="text-gray-500 text-sm">{notes}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="text-center mt-10">
          <a href="/experience" class="btn-secondary">Full Journey →</a>
        </div>
      </div>
    </section>

    <!-- ─── TESTIMONIALS ──────────────────────────────────────── -->
    <section class="py-20 md:py-28 bg-gray-50">
      <div class="max-w-6xl mx-auto px-4 md:px-8">
        <div class="text-center mb-14">
          <span class="tag mb-4">Testimonials</span>
          <h2 class="section-title">What People Say</h2>
          <p class="section-subtitle mx-auto">
            4.8/5 across 26 teacher responses · 100% would work with me again. Here's what a few of them said.
          </p>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          {[
            {
              quote: 'Luis Carlos has consistently been patient, responsive, and incredibly helpful, often taking the time to troubleshoot problems thoroughly and ensure that things were fully resolved. His support has significantly reduced stress for many of us and has made a complicated process much smoother.',
              name: 'Elizabeth Keogh',
              role: 'Grade 3 Teacher · unsolicited commendation to the Head of School',
              org: 'AISC',
            },
            {
              quote: 'Over the past year, we have been working to move all of our curriculum documentation into a shared Google Drive structure to create greater consistency, accessibility, and alignment across the school.',
              name: 'Joel Bevans',
              role: 'Director of Teaching & Learning',
              org: 'AISC, sent while introducing my system to 26 incoming teachers as their first onboarding resource',
            },
            {
              quote: 'Many students shared afterward how motivated they felt by your feedback. We are deeply grateful for your time and support of our Grade 8 learners.',
              name: 'Jonathan Wood, PhD',
              role: 'MS Social Studies Teacher',
              org: 'AISC, on the Grade 8 Tech Investor Summit',
            },
            {
              quote: 'Thank you so much for your help on this. It has made a massive difference in our department.',
              name: 'Jay Hart',
              role: 'MS Design Technology Teacher',
              org: 'AISC, on the consent-tracking system I built for his department',
            },
            {
              quote: 'This spreadsheet is incredible, and the video is so concise and clear.',
              name: 'Kelsey Bull',
              role: 'MS Principal',
              org: 'AISC, on the Science report-comment generator',
            },
            {
              quote: 'This is phenomenal work throughout this year that has provided extensive insight into our program.',
              name: 'Gretchen Galaty',
              role: 'High School Teacher',
              org: 'AISC',
            },
          ].map(({ quote, name, role, org }) => (
            <div class="card flex flex-col gap-4">
              <svg class="w-8 h-8 text-teal-200 flex-shrink-0" fill="currentColor" viewBox="0 0 32 32">
                <path d="M10 8C5.582 8 2 11.582 2 16s3.582 8 8 8h1v4l6-4h3c4.418 0 8-3.582 8-8s-3.582-8-8-8H10z"/>
              </svg>
              <p class="text-gray-700 leading-relaxed flex-1 italic">"{quote}"</p>
              <div class="pt-2 border-t border-gray-100">
                <p class="font-semibold text-navy text-sm">{name}</p>
                <p class="text-gray-500 text-xs">{role} · {org}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── CTA ───────────────────────────────────────────────── -->
    <section class="py-20 md:py-28 bg-navy text-white">
      <div class="max-w-3xl mx-auto px-4 md:px-8 text-center">
        <span class="tag bg-white/10 text-white border border-white/20 mb-6 inline-block">Let's Connect</span>
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          Ready to bring AI integration, instructional coaching, or systems thinking to your school or team?
        </h2>
        <p class="text-gray-300 text-lg mb-10">
          Whether you're a school leader exploring AI integration, an educator looking for coaching support,
          or a professional wanting to work smarter, let's start a conversation.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/work-with-me" class="btn-amber">Work With Me</a>
          <a href="mailto:mr.luisc@gmail.com" class="btn-secondary border-white/40 text-white hover:bg-white hover:text-teal">
            Send an Email
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
